KAFKA_BOOTSTRAP_SERVERS=your-kafka.aivencloud.com:PORT
KAFKA_TOPIC=text-analysis
KAFKA_GROUP_ID=text-analysis-workers
KAFKA_USE_SSL=true

POSTGRES_URL=postgres://avnadmin:PASSWORD@your-pg.aivencloud.com:PORT/defaultdb?sslmode=require

REDIS_URL=rediss://default:PASSWORD@your-redis.cloud.redislabs.com:PORT

S3_ENDPOINT_URL=https://s3.sufy.io
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=text-analysis-results
S3_REGION=auto
